        {
          "name": "Id",
          "type": "int",
          "isKey": true,
          "identity": true
        },
        {
          "name": "CustomerNumber",
          "type": "string",
          "required": true,
          "maxLength": 20,
          "unique": true
        },
        {
          "name": "CustomerName",
          "type": "string",
          "required": true,
          "maxLength": 200
        },
        {
          "name": "CustomerType",
          "type": "string",
