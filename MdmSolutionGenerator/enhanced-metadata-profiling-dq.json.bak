        {
          "ruleCode": "MATERIAL_NET_WEIGHT_NOT_GREATER_THAN_GROSS",
          "ruleName": "Material net weight must not exceed gross weight",
          "level": "BusinessObjectRoot",
          "entity": "Material",
          "category": "Accuracy",
          "severity": "High",
          "enforcement": "Block",
          "executionScopes": [
            "Create",
            "Update",
            "Profiling"
          ],
          "ruleType": "FieldComparisonRule",
          "message": "Net weight cannot be greater than gross weight.",
          "condition": {
            "type": "LessThanOrEqualField",
            "leftField": "NetWeight",
            "rightField": "GrossWeight",
            "ignoreNull": true
          }
        },
        {
          "ruleCode": "BATCH_MANAGED_MATERIAL_REQUIRES_INSPECTION",
