          "ruleType": "CustomCodeRule",
          "message": "Indian active customer must have a GST tax number.",
          "dependsOnEntities": [
            "Customer",
            "CustomerTax",
            "Country"
          ],
          "implementation": {
            "className": "CustomerIndiaGstTaxRequiredRule",
