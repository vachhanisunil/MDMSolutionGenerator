        {
          "ruleCode": "CUSTOMER_CUSTOMERNUMBER_REQUIRED",
          "ruleName": "Customer.CustomerNumber is mandatory",
          "level": "BusinessObjectRoot",
          "entity": "Customer",
          "category": "Completeness",
          "severity": "High",
          "enforcement": "Block",
          "executionScopes": [
            "Create",
            "Update",
            "Profiling"
          ],
          "ruleType": "FieldRule",
          "message": "Customer.CustomerNumber is required.",
