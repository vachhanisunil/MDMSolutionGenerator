            "Corporate",
            "Government",
            "Distributor"
          ]
        },
        {
          "name": "Email",
          "type": "string",
          "email": true,
          "maxLength": 250
        },
        {
          "name": "Phone",
          "type": "string",
          "maxLength": 30
        },
        {
          "name": "CountryId",
          "type": "int",
          "required": true,
          "index": true
        },
        {
          "name": "CurrencyId",
          "type": "int",
          "required": true,
          "index": true
        },
        {
          "name": "IndustryCode",
          "type": "string",
          "maxLength": 30,
