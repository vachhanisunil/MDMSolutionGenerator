        {
          "ruleCode": "ACTIVE_MATERIAL_REQUIRES_PLANT",
          "ruleName": "Active material must be extended to at least one plant",
          "level": "BusinessObject",
          "entity": "MaterialPlant",
          "category": "Integrity",
          "severity": "High",
          "enforcement": "Block",
          "executionScopes": [
            "Create",
            "Update",
            "Profiling"
          ],
          "ruleType": "RelationshipRule",
          "message": "Active material must have at least one plant extension.",
          "dependsOnEntities": [
            "Material",
            "MaterialPlant"
          ],
          "condition": {
            "parentFilter": {
              "field": "IsActive",
              "operator": "Equals",
              "value": true
            },
            "relationship": {
              "parentEntity": "Material",
              "childEntity": "MaterialPlant",
              "parentKey": "Id",
              "childForeignKey": "MaterialId"
            },
            "childRequirement": {
              "type": "AtLeastOne"
            }
          }
        },
