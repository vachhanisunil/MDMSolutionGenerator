        {
          "ruleCode": "CUSTOMER_CREDIT_EXPOSURE_WITHIN_LIMIT",
          "ruleName": "Customer credit exposure should not exceed credit limit",
          "level": "ChildEntity",
          "entity": "CustomerCreditProfile",
          "category": "Accuracy",
          "severity": "High",
          "enforcement": "Block",
          "executionScopes": [
            "Create",
            "Update",
            "Profiling"
          ],
          "ruleType": "FieldComparisonRule",
          "message": "Credit exposure cannot exceed credit limit.",
          "condition": {
            "type": "LessThanOrEqualField",
            "leftField": "CreditExposure",
            "rightField": "CreditLimit",
            "ignoreNull": true
          }
        }
