          "ruleCode": "VENDOR_APPROVED_REQUIRES_DEFAULT_ADDRESS",
          "ruleName": "Approved vendor must have one default address",
          "level": "BusinessObject",
          "entity": "VendorAddress",
          "category": "Integrity",
          "severity": "High",
          "enforcement": "Block",
          "executionScopes": [
            "Create",
            "Update",
            "Profiling"
          ],
          "ruleType": "RelationshipRule",
          "message": "Approved vendor must have at least one default address.",
          "dependsOnEntities": [
            "Vendor",
            "VendorAddress"
          ],
          "condition": {
            "parentFilter": {
              "field": "OnboardingStatus",
              "operator": "Equals",
              "value": "Approved"
            },
            "relationship": {
              "parentEntity": "Vendor",
              "childEntity": "VendorAddress",
              "parentKey": "Id",
              "childForeignKey": "VendorId"
            },
            "childRequirement": {
              "type": "AtLeastOne",
              "filter": {
                "field": "IsDefault",
                "operator": "Equals",
                "value": true
              }
            }
          }
        },
