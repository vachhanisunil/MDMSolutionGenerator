        {
          "ruleCode": "CUSTOMER_ACTIVE_REQUIRES_DEFAULT_ADDRESS",
          "ruleName": "Active customer must have one default address",
          "level": "BusinessObject",
          "entity": "CustomerAddress",
          "category": "Integrity",
          "severity": "High",
          "enforcement": "Block",
          "executionScopes": [
            "Create",
            "Update",
            "Profiling"
          ],
          "ruleType": "RelationshipRule",
          "message": "Active customer must have at least one default address.",
          "dependsOnEntities": [
            "Customer",
            "CustomerAddress"
